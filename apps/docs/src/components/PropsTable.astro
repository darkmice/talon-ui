import propsJson from '../../.generated/props.json';

interface Props {
  component: string;
}

const { component } = Astro.props;
type PropEntry = {
  name: string;
  type: string;
  required: boolean;
  defaultValue: string | null;
  description: string;
};
type ComponentDocs = { displayName: string; description: string; props: PropEntry[] };

const all = propsJson as Record<string, ComponentDocs>;
const doc = all[component];
---

{!doc && (
  <p class="text-caption" style="color: var(--tp-status-pending-fg)">
    Props for <code>{component}</code> not found in the generated docs. Run <code>pnpm --filter @talon-ui/docs build</code> after building <code>@talon-ui/react</code>.
  </p>
)}

{doc && doc.props.length === 0 && (
  <p class="text-caption" style="color: var(--tp-text-tertiary)">
    <code>{component}</code> has no own props (all attributes are inherited from the underlying element).
  </p>
)}

{doc && doc.props.length > 0 && (
  <table class="tp-props-table">
    <thead>
      <tr>
        <th>Prop</th>
        <th>Type</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {doc.props.map((p) => (
        <tr>
          <td>
            <code>{p.name}</code>
            {p.required && <span class="tp-required" title="Required">*</span>}
          </td>
          <td><code>{p.type}</code></td>
          <td>{p.defaultValue ? <code>{p.defaultValue}</code> : <span class="tp-na">—</span>}</td>
          <td>{p.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
)}

<style>
  .tp-props-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--tp-fs-caption);
    margin: var(--tp-space-3) 0;
  }
  .tp-props-table th {
    text-align: left;
    padding: var(--tp-space-2) var(--tp-space-3);
    border-bottom: 1px solid var(--tp-border-default);
    color: var(--tp-text-secondary);
    font-weight: var(--tp-fw-medium);
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .tp-props-table td {
    padding: var(--tp-space-2) var(--tp-space-3);
    border-bottom: 1px solid var(--tp-border-subtle);
    vertical-align: top;
  }
  .tp-props-table tbody tr:last-child td {
    border-bottom: none;
  }
  .tp-props-table code {
    font-family: var(--tp-font-mono);
    font-size: 0.875em;
  }
  .tp-required {
    margin-left: 4px;
    color: var(--tp-danger-500);
  }
  .tp-na {
    color: var(--tp-text-tertiary);
  }
</style>
